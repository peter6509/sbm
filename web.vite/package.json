    "@visactor/vtable-gantt": "^1.19.4",
    "ali-oss": "^6.23.0",
    "axios": "^1.3.4",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "less": "^4.4.0",
    "pinia": "^3.0.3",
    "qrcode.vue": "^3.6.0",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.13",
    "vue-draggable-next": "^2.2.1",
    "vue-grid-layout": "^3.0.0-beta1",
    "vue-plugin-hiprint": "^0.0.19",
